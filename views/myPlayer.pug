extends template.pug 

block content
    if players && players.length
        .players
            each p in players
                .player(id='id_' + p.id)
                    .playerContent
                        .playerInfo
                            h2= p.name
                            h3= p.team
                            p= p.description
                            p Stat Points: #{p.statPoints}

                            p Layup: #{p.lay} | Mid-Range: #{p.mR} | 3PT: #{p.tP} | Dunk: #{p.dunk} | Defence: #{p.def} 
                            p Rebound: #{p.reb} | Handles: #{p.hand} | Passing: #{p.pass} | Speed: #{p.spd}

                            form(action="/myPlayer/upgrade/" + p.id, method="get")
                                button(type="submit") Upgrade Player
                            form(action="/myPlayer/delete/" + p.id, method="post")
                                button(type="submit", onclick="return confirm('Are you sure you want to delete this player?')") Delete Player

                        .overallBox
                            - const overall = (Number(p.lay) || 0) + (Number(p.mR) || 0) + (Number(p.tP) || 0) + (Number(p.dunk) || 0) + (Number(p.def) || 0) + (Number(p.reb) || 0) + (Number(p.hand) || 0) + (Number(p.pass) || 0) + (Number(p.spd) || 0)
                            - const overallAvg = overall / 9

                            h1= Math.round(overallAvg)
                            p Overall

    else
        p No players found.

block form
    .footerDiv
        form(action="/myPlayer/create", method="post")

            .field.name
                label Player Name
                input(type="text", name="name", required)

            .field.team
                label Team
                select(name="team", required)
                    option(value="") Select Team
                    each t in teams
                        option(value=t selected=(team==t))= t

            .field
                label Layup
                input(type="number", name="lay", min="25", max="99", required)

            .field
                label Mid-Range
                input(type="number", name="mR", min="25", max="99", required)

            .field
                label 3PT
                input(type="number", name="tP", min="25", max="99", required)

            .field
                label Dunk
                input(type="number", name="dunk", min="25", max="99", required)

            .field
                label Defence
                input(type="number", name="def", min="25", max="99", required)

            .field
                label Rebound
                input(type="number", name="reb", min="25", max="99", required)

            .field
                label Handles
                input(type="number", name="hand", min="25", max="99", required)

            .field
                label Passing
                input(type="number", name="pass", min="25", max="99", required)

            .field
                label Speed
                input(type="number", name="spd", min="25", max="99", required)

            .field.desc
                label Description
                textarea(name="description", required)

            button(type="submit") Create Player

