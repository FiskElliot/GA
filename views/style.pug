style.
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, Helvetica, sans-serif;
    }

    body {
        background: #0f172a;
        color: #e2e8f0;
    }

    /* NAVBAR */
    nav {
        background: #020617;
        padding: 15px;
        display: flex;
        gap: 20px;
        justify-content: center;
        border-bottom: 2px solid #1e293b;
    }

    nav a {
        color: #e2e8f0;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

    nav a:hover {
        color: #38bdf8;
    }

    /* HEADER */
    .headerDiv {
        text-align: center;
        padding: 30px 10px;
    }

    .headerDiv h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    /* MAIN */
    .mainDiv {
        text-align: center;
        padding: 20px;
    }

    /* PLAYER GRID */
    .players {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        padding: 20px;
    }

    /* PLAYER CARD */
    .player {
        background: #020617;
        border-radius: 15px;
        padding: 15px;
        transition: 0.3s;
        border: 1px solid #1e293b;
    }

    .player:hover {
        transform: scale(1.03);
        border-color: #38bdf8;
    }

    .player img {
        width: 100%;
        border-radius: 10px;
        margin-bottom: 10px;
    }

    .playerContent {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .playerInfo {
        flex: 2;
    }

    .playerInfo h2 {
        margin-bottom: 5px;
    }

    .playerInfo h3 {
        color: #38bdf8;
        margin-bottom: 10px;
    }

    .playerInfo p {
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    /* OVERALL BOX */
    .overallBox {
        flex: 1;
        background: #1e293b;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px;
    }

    .overallBox h1 {
        font-size: 2rem;
        color: #22c55e;
    }

    /* BUTTONS */
    button {
        margin-top: 8px;
        padding: 8px 12px;
        border: none;
        border-radius: 8px;
        background: #38bdf8;
        color: black;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

    button:hover {
        background: #0ea5e9;
    }

    form {
        margin-top: 5px;
    }

    /* FORM (CREATE PLAYER) */
    .footerDiv {
        background: #020617;
        padding: 20px;
        margin-top: 30px;
        border-top: 2px solid #1e293b;
    }


    .footerDiv form {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        max-width: 900px;
        margin: auto;
    }

    .field {
        display: flex;
        flex-direction: column;
    }

    .field.name {
        grid-column: span 2;
    }

    .field.team {
        grid-column: span 2;
    }

    .field.desc {
        grid-column: span 4;
    }

    textarea {
        min-height: 80px;
    }

    button {
        grid-column: span 4;
    }

    textarea {
        grid-column: span 2;
        min-height: 80px;
    }

    label {
        font-size: 0.8rem;
    }

    /* SINGLE PLAYER PAGE */
    .singlePlayer {
        text-align: center;
        padding: 20px;
    }

    .singlePlayer img {
        width: 300px;
        border-radius: 15px;
        margin-bottom: 15px;
    }

    .stats p {
        margin: 5px 0;
    }

    .backBtn {
        display: inline-block;
        margin-top: 15px;
        text-decoration: none;
        color: #38bdf8;
    }

    /* UPGRADE PAGE */
    h1, h2 {
        text-align: center;
        margin: 10px 0;
    }

    hr {
        margin: 10px 0;
        border: 1px solid #1e293b;
    }

    /* RESPONSIVE */
    @media (max-width: 600px) {
        .playerContent {
            flex-direction: column;
        }

        .overallBox {
            margin-top: 10px;
        }
    }
