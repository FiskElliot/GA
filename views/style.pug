style.
  /* modern dark mode with glass effect */
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: linear-gradient(145deg,#141e30,#243b55);
    font-family: 'Roboto', sans-serif;
    color: #e0e0e0;
  }

  header, footer {
    padding: 1rem;
    text-align: center;
    backdrop-filter: blur(6px);
    background: rgba(20,30,48,0.6);
    color: #fff;
  }

  .headerDiv {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .headerDiv h1 {
    margin: 0;
    font-size: 2rem;
    letter-spacing: 1px;
  }

  .headerDiv form {
    display: flex;
    gap: 0.5rem;
  }

  select, input[type="search"], input[type="text"], textarea {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    color: #fff;
    font-size: 0.95rem;
    transition: background 0.2s, border-color 0.2s;
  }

  /* ensure option text is visible */
  select option {
    background: #141e30; /* dark background inside dropdown */
    color: #e0e0e0;
  }

  select:focus, input:focus, textarea:focus {
    outline: none;
    background: rgba(255,255,255,0.2);
    border-color: #00e5ff;
  }

  .players {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
    gap: 1.5rem;
    padding: 2rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .player {
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .player:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.3);
  }

  .player img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }

  .player h3 {
    margin: 0.75rem 1rem 0.25rem;
    font-size: 1.1rem;
    color: #00e5ff;
  }

  .player p {
    margin: 0 1rem 1rem;
    font-size: 0.9rem;
    color: #cfd8dc;
  }

  a {
    color: #00e5ff;
    text-decoration: none;
    position: relative;
  }

  a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 2px;
    background: #00e5ff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  a:hover::after {
    transform: scaleX(1);
  }

  button {
    background: #00e5ff;
    color: #141e30;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
  }

  button:hover {
    background: #00bcd4;
    transform: translateY(-2px);
  }

  footer .footerDiv {
    font-size: 0.8rem;
    color: #aaa;
  }

