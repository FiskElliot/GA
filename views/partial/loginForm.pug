.form-container
    h2 Logga in
    if error
        p.error= error
    form(action="/main/login" method="POST" hx-post="/main/login" hx-target="this" hx-swap="outerHTML")
        label(for="email") Email:
        input(type="email" name="email" required)

        label(for="pin") PIN:
        input(type="password" name="pin" required)

        button(type="submit") Logga in