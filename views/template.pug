doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        include style.pug 
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Document
    header
        nav 
            a(href="/main") Login/Register
            a(href="/myPlayer") MyPlayer
            a(href="/myTeam") MyTeam 
            a(href="/players") Players

            if loggedIn
                .loginStatus 
                    p You are logged in as #{email}
                    a(href="/logout") Log Out 
            else
                .loginStatus 
                    p You are not logged in

    main
        block content
            .mainDiv 
                h2 Register user
                form(action="/main/register" method="POST")
                    label(for="email") Email:
                    input(type="email" name="email" required)

                    label(for="pin") PIN:
                    input(type="password" name="pin" required)

                    button(type="submit") Register

                hr

                h2 Logga in
                form(action="/main/login" method="POST")
                    label(for="email") Email:
                    input(type="email" name="email" required)

                    label(for="pin") PIN:
                    input(type="password" name="pin" required)

                    button(type="submit") Logga in

    footer
        block form
             .footerDiv
                p &copy; 2024 My Pug Template. All rights reserved. 

    block mPScripts